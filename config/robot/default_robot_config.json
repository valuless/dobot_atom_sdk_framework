{
    "robot": {
        "ip": "192.168.8.234",
        "port": 50051,
        "timeout": 5.0,
        "retry_count": 3,
        "retry_delay": 1.0
    },

    "motion": {
        "control_frequency": 100.0,
        "max_joint_velocity": 2.0,
        "max_joint_acceleration": 4.0,
        "max_cartesian_velocity": 1.0,
        "max_cartesian_acceleration": 2.0,
        "joint_limits": {
            "j1": [-3.14, 3.14],
            "j2": [-1.57, 1.57],
            "j3": [-3.14, 3.14],
            "j4": [-3.14, 3.14],
            "j5": [-1.57, 1.57],
            "j6": [-3.14, 3.14]
        },
        "workspace_limits": {
            "x": [-1.0, 1.0],
            "y": [-1.0, 1.0],
            "z": [0.0, 1.5]
        }
    },

    "monitoring": {
        "update_frequency": 50.0,
        "enable_joint_monitoring": true,
        "enable_system_monitoring": true,
        "joint_temperature_threshold": 60.0,
        "warning_temperature_threshold": 50.0,
        "error_threshold": 1
