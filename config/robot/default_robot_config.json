    "logging": {
        "level": "INFO",
        "enable_file_logging": true,
        "log_file": "robot.log",
        "max_log_size": "10MB",
        "max_backup_count": 5
    },

    "dds": {
        "domain_id": 0,
        "participant_name": "robot_participant",
        "network_interface": "eth0"
    },

    "trajectory": {
        "smoothing_enabled": true,
        "smoothing_time": 0.1,
        "planning_time_limit": 5.0,
        "enable_replanning": true
    },

    "fsm_modes": {
        "idle": 100,
        "ready": 101,
        "emergency": 102,
        "manual": 200,
        "auto": 300,
        "walking": 301,
        "balance": 302
